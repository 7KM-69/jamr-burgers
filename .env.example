# JAMR — environment variables
# Copy to `.env.local` and fill in. `.env.local` is NEVER committed.
# This file carries NAMES ONLY. Never put a real value in it.

# ---------------------------------------------------------------------------
# Supabase — public values. Safe to ship to the browser.
# The anon key is public BY DESIGN; Row Level Security is what protects your
# data, not the secrecy of this key.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ---------------------------------------------------------------------------
# Supabase — SECRET. Server only.
#
# This key BYPASSES EVERY RLS POLICY. In a client bundle it hands a stranger
# the entire database: every user's orders, every profile.
#
#   - It must NEVER be prefixed with NEXT_PUBLIC_.
#   - It must NEVER be imported into a client component.
#   - It must NEVER be returned from a route handler or server action.
#
# As of wave 1 NO application code reads this variable. It is documented here
# only so it is not accidentally recreated with the wrong name later.
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ---------------------------------------------------------------------------
# There is NO payment provider in this project, by design (see CLAUDE.md).
# Checkout is simulated. If you ever find a Stripe/Tap/Moyasar/PayPal key in
# this file, someone has broken a hard rule — remove it.
# ---------------------------------------------------------------------------
